  "config_path": "/etc/prometheus/prometheus.yml",
  "description": "Prometheus Stack bundles Prometheus, Alertmanager, and Blackbox Exporter in a single LXC container. Prometheus collects and stores metrics; Alertmanager handles alerts and routes notifications; Blackbox Exporter probes endpoints over HTTP, HTTPS, DNS, TCP, ICMP, and gRPC.",
  "install_methods": [
    {
      "type": "default",
      "script": "ct/prometheus-stack.sh",
      "resources": {
        "cpu": 2,
        "ram": 2048,
        "hdd": 8,
        "os": "debian",
        "version": "13"
      }
    }
  ],
  "default_credentials": {
    "username": null,
    "password": null
  },
