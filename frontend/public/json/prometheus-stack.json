    {
      "text": "Prometheus listens on port **9090**",
      "type": "info"
    },
    {
      "text": "Alertmanager listens on port **9093**",
      "type": "info"
    },
    {
      "text": "Blackbox Exporter listens on port **9115**",
      "type": "info"
    },
    {
      "text": "Prometheus config: `/etc/prometheus/prometheus.yml`",
      "type": "info"
    },
    {
      "text": "Alertmanager config: `/etc/alertmanager/alertmanager.yml`",
      "type": "info"
    },
    {
      "text": "Blackbox Exporter config: `/opt/blackbox-exporter/blackbox.yml`",
      "type": "info"
    }
  ]
